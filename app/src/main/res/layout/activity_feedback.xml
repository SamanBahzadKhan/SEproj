<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_feedback_bg"
    android:orientation="vertical">

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/caps_feedback_topbar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_feedback_back_circle"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/press_down_button">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_back"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_arrow_back_black" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:text="Leave Feedback"
                android:textColor="@color/caps_palette_white"
                android:textSize="20sp" />
        </FrameLayout>

        <View
            android:layout_width="44dp"
            android:layout_height="1dp"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_feedback_counselor_card"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_feedback_avatar">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="@color/caps_palette_white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvCounselorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvSpecialization"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:textColor="@color/caps_feedback_spec_blue_grey"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAppointmentDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:textColor="@color/caps_palette_grey_warm"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="RATE YOUR SESSION"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/rowStars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_feedback_star_cell_empty"
                    android:contentDescription="1"
                    android:padding="8dp"
                    android:src="@drawable/ic_star_outline"
                    android:stateListAnimator="@animator/press_down_button"
                    android:tint="@color/caps_feedback_star_peach" />

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_feedback_star_cell_empty"
                    android:contentDescription="2"
                    android:padding="8dp"
                    android:src="@drawable/ic_star_outline"
                    android:stateListAnimator="@animator/press_down_button"
                    android:tint="@color/caps_feedback_star_peach" />

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_feedback_star_cell_empty"
                    android:contentDescription="3"
                    android:padding="8dp"
                    android:src="@drawable/ic_star_outline"
                    android:stateListAnimator="@animator/press_down_button"
                    android:tint="@color/caps_feedback_star_peach" />

                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_feedback_star_cell_empty"
                    android:contentDescription="4"
                    android:padding="8dp"
                    android:src="@drawable/ic_star_outline"
                    android:stateListAnimator="@animator/press_down_button"
                    android:tint="@color/caps_feedback_star_peach" />

                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_feedback_star_cell_empty"
                    android:contentDescription="5"
                    android:padding="8dp"
                    android:src="@drawable/ic_star_outline"
                    android:stateListAnimator="@animator/press_down_button"
                    android:tint="@color/caps_feedback_star_peach" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="YOUR COMMENTS"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_feedback_comment_box"
                android:fontFamily="sans-serif"
                android:gravity="top|start"
                android:hint="Share your experience with this counsellor..."
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="150dp"
                android:padding="16dp"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textColorHint="@color/caps_palette_grey_warm"
                android:textSize="15sp" />

            <FrameLayout
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_feedback_submit"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/press_down_button">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="false"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:text="SUBMIT FEEDBACK"
                    android:textAllCaps="true"
                    android:textColor="@color/caps_palette_white"
                    android:textSize="15sp" />
            </FrameLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
