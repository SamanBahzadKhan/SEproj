<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tvVerifyTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Verify Your Email"
        android:textColor="@color/caps_palette_neutral_dark"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvVerifyBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/caps_palette_grey_warm"
        android:textSize="15sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_offset_button_bluegrey_12">

        <Button
            android:id="@+id/btnVerifiedContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-black"
            android:text="I've Verified — Continue"
            android:textAllCaps="false"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="15sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvResendEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif"
        android:padding="8dp"
        android:text="Resend Email"
        android:textColor="@color/caps_palette_green_soft"
        android:textSize="13sp" />
</LinearLayout>
