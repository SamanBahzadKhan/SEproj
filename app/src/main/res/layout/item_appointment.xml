<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_past_card_shadow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_past_card_foreground"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPrimaryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOverflow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="..."
                    android:textColor="@color/caps_palette_grey_warm"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvStatusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_status_booked"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/caps_palette_white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="56sp" />

        <TextView
            android:id="@+id/tvSecondaryLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/caps_palette_grey_warm"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDurationChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_offset_chip_small"
                android:fontFamily="sans-serif"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="1 hour"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_offset_chip_small"
                android:fontFamily="sans-serif"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowStudentActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReschedule"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1.35"
                android:background="@drawable/bg_offset_btn_reschedule"
                android:fontFamily="sans-serif-black"
                android:stateListAnimator="@animator/press_down_button"
                android:text="Reschedule"
                android:textAllCaps="false"
                android:textColor="@color/caps_palette_white"
                android:textSize="15sp"
                app:backgroundTint="@android:color/transparent"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelStudent"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_offset_btn_cancel_outline"
                android:fontFamily="sans-serif-black"
                android:stateListAnimator="@animator/press_down_button"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="15sp"
                app:backgroundTint="@android:color/transparent"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="FEEDBACK"
            android:textColor="#5BA3D9"
            android:visibility="gone"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#5BA3D9"
            app:strokeWidth="2dp" />

        <FrameLayout
            android:id="@+id/rowRecordDiagnosis"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_session_add_med"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecordDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_gravity="top|start"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-black"
                android:stateListAnimator="@animator/press_down_button"
                android:text="Record Diagnosis"
                android:textAllCaps="false"
                android:textColor="@color/caps_palette_white"
                android:textSize="15sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:strokeWidth="0dp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/rowCounselorActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btnComplete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_offset_circle_36_sage"
                android:contentDescription="Complete"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_check_white_24" />

            <ImageButton
                android:id="@+id/btnNoShow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="No show"
                android:padding="8dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnCancelCounselor"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_offset_circle_36_rose"
                android:contentDescription="Cancel"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_close_white_24"
                android:tint="@color/caps_palette_neutral_dark" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSessionNotesHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:text="@string/student_past_card_session_notes_hint"
            android:textColor="@color/caps_palette_blue"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>