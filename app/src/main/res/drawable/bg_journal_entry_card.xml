<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="6dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/caps_palette_neutral_dark" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/caps_palette_white" />
            <stroke
                android:width="2dp"
                android:color="@color/caps_palette_neutral_dark" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
