<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_offset_row_12"
    android:padding="12dp"
    android:stateListAnimator="@animator/press_down_button">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvReportedName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvReportType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_offset_report_type_badge"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="11sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvReporter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/caps_palette_grey_warm"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvReportSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="2"
            android:textColor="@color/caps_palette_grey_warm"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvReportTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/caps_palette_footer"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/btnReportRemove"
                android:layout_width="86dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_offset_report_remove_btn"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/press_down_button">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="REMOVE"
                    android:textColor="@color/caps_palette_white"
                    android:textSize="13sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnReportIgnore"
                android:layout_width="86dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_offset_report_ignore_btn"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/press_down_button">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="IGNORE"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="13sp" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
