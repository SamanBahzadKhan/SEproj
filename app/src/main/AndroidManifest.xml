<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CAPs">

        <activity
            android:name=".views.activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".views.activities.LoginActivity" />
        <activity android:name=".views.activities.RegisterActivity" />
        <activity android:name=".views.activities.StudentDashboardActivity" />
        <activity android:name=".views.activities.CounselorDashboardActivity" />
        <activity android:name=".views.activities.AdminDashboardActivity" />
        <activity android:name=".views.activities.CounselorListActivity" />
        <activity android:name=".views.activities.CounselorProfileActivity" />
        <activity android:name=".views.activities.TimeSlotsActivity" />
        <activity android:name=".views.activities.BookAppointmentActivity" />
        <activity android:name=".views.activities.ProfileActivity" />
        <activity android:name=".views.activities.NotificationsActivity" />
        <activity android:name=".views.activities.AppointmentsActivity" />
        <activity android:name=".views.activities.FeedbackActivity" />
        <activity android:name=".views.activities.AvailabilityActivity" />
    </application>

</manifest>
