<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp">
                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_blue_bg" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="👤"
                    android:textSize="22sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPrimaryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2A4A6B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSecondaryLine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5BA3D9"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#2A4A6B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#666666"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/rowStudentActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReschedule"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="RESCHEDULE"
                android:textColor="#FFA000"
                app:backgroundTint="@android:color/transparent"
                app:strokeColor="#FFA000"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelStudent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#F44336"
                android:text="CANCEL"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="FEEDBACK"
            android:textColor="#5BA3D9"
            android:visibility="gone"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#5BA3D9"
            app:strokeWidth="2dp" />

        <LinearLayout
            android:id="@+id/rowCounselorActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btnComplete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_green"
                android:contentDescription="Complete"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_check_white_24" />

            <ImageButton
                android:id="@+id/btnNoShow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="No show"
                android:padding="8dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnCancelCounselor"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle_red"
                android:contentDescription="Cancel"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_close_white_24" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
