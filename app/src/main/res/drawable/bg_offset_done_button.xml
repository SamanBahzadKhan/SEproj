        <shape android:shape="rectangle">
            <solid android:color="@color/caps_palette_neutral_dark" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/caps_palette_green_soft" />
