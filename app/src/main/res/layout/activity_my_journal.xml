<?xml version="1.0" encoding="utf-8"?>
<!-- My Journal: stats row, new entry, recent entries (neo-brutalist mockup). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_brut_cream_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/caps_journal_topbar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="12dp">

        <FrameLayout
            android:id="@+id/btnJournalBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_journal_back_circle"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/press_down_button">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_back"
                android:src="@drawable/ic_arrow_back_navy" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="My Journal"
            android:textColor="@color/caps_palette_white"
            android:textSize="18sp" />

        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_journal_stat_blue"
                    android:gravity="center_horizontal"
                    android:minHeight="112dp"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/caps_brut_navy" />

                    <TextView
                        android:id="@+id/tvStatTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="@color/caps_brut_navy"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.06"
                        android:text="TOTAL ENTRIES"
                        android:textAllCaps="true"
                        android:textColor="@color/caps_brut_navy"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_journal_stat_sage"
                    android:gravity="center_horizontal"
                    android:minHeight="112dp"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@android:drawable/stat_sys_upload"
                        app:tint="@color/caps_brut_navy" />

                    <TextView
                        android:id="@+id/tvStatStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="@color/caps_brut_navy"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.06"
                        android:text="DAY STREAK"
                        android:textAllCaps="true"
                        android:textColor="@color/caps_brut_navy"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_journal_stat_peach"
                    android:gravity="center_horizontal"
                    android:minHeight="112dp"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_journal_heart" />

                    <TextView
                        android:id="@+id/tvStatWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="@color/caps_brut_navy"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.06"
                        android:text="THIS WEEK"
                        android:textAllCaps="true"
                        android:textColor="@color/caps_brut_navy"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_journal_new_entry_btn">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewJournalEntry"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_gravity="top|start"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@animator/press_down_button"
                    android:text="+ New Journal Entry"
                    android:textAllCaps="false"
                    android:textColor="@color/caps_palette_white"
                    android:textSize="16sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="0dp"
                    app:strokeWidth="0dp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="RECENT ENTRIES"
                android:textAllCaps="true"
                android:textColor="@color/caps_brut_navy"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvJournalEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:padding="20dp"
                android:text="No entries yet. Tap + New Journal Entry to begin."
                android:textColor="@color/caps_brut_blue_gray"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvJournalEntries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
