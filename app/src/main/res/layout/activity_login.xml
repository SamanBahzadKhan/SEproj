<?xml version="1.0" encoding="utf-8"?>
<!-- activity_login.xml: Login screen layout for student, counselor, and admin authentication. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_palette_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_marginTop="48dp"
                android:background="@drawable/bg_offset_logo_80">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_splash_heart_filled"
                    android:tint="@color/caps_palette_white" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Welcome"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="30sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Sign in to continue"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="15sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_offset_input_12">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="10dp"
                    android:fontFamily="sans-serif"
                    android:hint="Student ID or Email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textColorHint="@color/caps_palette_grey_warm"
                    android:textSize="15sp" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_offset_input_12">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_lock_lock"
                    android:drawableEnd="@android:drawable/ic_menu_view"
                    android:drawablePadding="10dp"
                    android:fontFamily="sans-serif"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textColorHint="@color/caps_palette_grey_warm"
                    android:textSize="15sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="sans-serif"
                android:padding="2dp"
                android:text="Forgot Password?"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_offset_button_rose_12">

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-black"
                    android:text="SIGN IN"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_offset_button_white_12">

                <Button
                    android:id="@+id/btnCounselorLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-black"
                    android:text="SIGN IN AS COUNSELLOR"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="16sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCounselorRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif"
                android:text="New counsellor? Register here"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRegisterLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:text="New student? Register here"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAdminLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif"
                android:text="Sign in as Admin"
                android:textAllCaps="false"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/caps_palette_brown"
        android:visibility="gone" />

</FrameLayout>