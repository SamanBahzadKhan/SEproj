<?xml version="1.0" encoding="utf-8"?>
<!-- Matches past appointment card stack (shadow + foreground) for dashboard consistency. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_past_card_shadow" />

    <LinearLayout
        android:id="@+id/cardInner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_past_card_foreground"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:stateListAnimator="@animator/press_down_button">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCounselorName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_completed"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="COMPLETED"
                android:textColor="@color/caps_palette_white"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSessionWhen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:text="Tap to view session notes"
            android:textColor="@color/caps_brut_blue_gray"
            android:textSize="13sp" />
    </LinearLayout>
</FrameLayout>
