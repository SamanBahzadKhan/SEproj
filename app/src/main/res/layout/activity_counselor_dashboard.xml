<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_palette_bg">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/caps_palette_text_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="CAPs"
                android:textColor="@color/caps_palette_white"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Counselling Appointment System"
                android:textColor="@color/caps_palette_blue_light"
                android:textSize="11sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/topBarBell"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_offset_circle_40_bell_admin">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_popup_reminder"
                android:tint="@color/caps_palette_neutral_dark" />

            <View
                android:id="@+id/bellBadge"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_badge_dot"
                android:visibility="gone" />
        </FrameLayout>

        <ImageView
            android:id="@+id/topBarSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_offset_circle_40_bell_admin"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="@color/caps_palette_neutral_dark"
            android:visibility="visible" />
    </LinearLayout>

    <View
        android:id="@+id/topDivider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/caps_palette_neutral_dark"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavCounselor"
        app:layout_constraintTop_toBottomOf="@id/topDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="16dp"
                android:fontFamily="sans-serif"
                android:text="Good Morning,"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:text="Dr. XYZ"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="16dp">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="98dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_offset_row_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            android:tint="@color/caps_palette_grey_warm" />

                        <TextView
                            android:id="@+id/tvTodayCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textColor="@color/caps_palette_grey_warm"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="98dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_offset_row_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_lock_idle_alarm"
                            android:tint="@color/caps_palette_grey_warm" />

                        <TextView
                            android:id="@+id/tvWeekCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="This Week"
                            android:textColor="@color/caps_palette_grey_warm"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="98dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_offset_row_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:tint="@color/caps_palette_grey_warm" />

                        <TextView
                            android:id="@+id/tvPending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textColor="@color/caps_palette_grey_warm"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditAvailability"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_offset_button_white_12"
                android:fontFamily="sans-serif-black"
                android:stateListAnimator="@animator/press_down_button"
                android:text="CHANGE AVAILABILITY"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_brown"
                android:textSize="14sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="12dp"
                app:strokeWidth="0dp" />

            <TextView
                android:id="@+id/labelPendingSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="PENDING REQUESTS"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="Today's Appointments"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/caps_palette_blue_grey"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="No appointments today."
                android:textColor="@color/caps_palette_grey_warm"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="My Availability"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_offset_row_16"
                android:padding="12dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <TableLayout
                        android:id="@+id/tableAvailability"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TableRow android:paddingBottom="6dp">
                            <TextView android:layout_width="56dp" android:layout_height="wrap_content" />
                            <TextView android:id="@+id/dayHeader0" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Mon" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                            <TextView android:id="@+id/dayHeader1" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Tue" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                            <TextView android:id="@+id/dayHeader2" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Wed" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                            <TextView android:id="@+id/dayHeader3" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Thu" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                            <TextView android:id="@+id/dayHeader4" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Fri" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                            <TextView android:id="@+id/dayHeader5" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Sat" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                            <TextView android:id="@+id/dayHeader6" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:text="Sun" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" android:fontFamily="sans-serif-black" />
                        </TableRow>

                        <TableRow android:paddingBottom="6dp">
                            <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:gravity="center_vertical" android:text="Morning" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" />
                            <FrameLayout android:id="@+id/cell_m0" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_m1" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_m2" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_m3" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_m4" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_m5" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_m6" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                        </TableRow>

                        <TableRow>
                            <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:gravity="center_vertical" android:text="Afternoon" android:textColor="@color/caps_palette_grey_warm" android:textSize="12sp" />
                            <FrameLayout android:id="@+id/cell_a0" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_a1" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_a2" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_a3" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_a4" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_a5" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                            <FrameLayout android:id="@+id/cell_a6" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="3dp" android:background="@drawable/bg_avail_cell_grey" />
                        </TableRow>
                    </TableLayout>
                </HorizontalScrollView>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomNavCounselor"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:background="@color/caps_palette_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="top"
            android:background="@color/caps_palette_neutral_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="@id/bottomNavCounselor"
        app:layout_constraintTop_toTopOf="@id/bottomNavCounselor">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_offset_home_icon">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/caps_palette_grey_warm" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Home"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCounsel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="@color/caps_palette_grey_warm" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Schedule"
                android:textColor="@color/caps_palette_grey_warm"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAppts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_agenda" android:tint="@color/caps_palette_grey_warm" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="Appointments" android:textColor="@color/caps_palette_grey_warm" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAlerts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_popup_reminder" android:tint="@color/caps_palette_grey_warm" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="Alerts" android:textColor="@color/caps_palette_grey_warm" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_myplaces" android:tint="@color/caps_palette_grey_warm" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="Profile" android:textColor="@color/caps_palette_grey_warm" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
