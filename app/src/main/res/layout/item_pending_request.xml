<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_pending_request_card_shadow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_pending_request_card_fg"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="16dp">

        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:textColor="@color/caps_palette_blue_grey"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_pending_type_pill"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textAllCaps="false"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="11sp" />
        </LinearLayout>

        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:gravity="end|top"
            android:orientation="horizontal"
            android:paddingTop="2dp">

            <ImageButton
                android:id="@+id/btnConfirm"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_offset_circle_48_sage"
                android:contentDescription="@string/cd_confirm_request"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_check_white_24"
                android:stateListAnimator="@animator/press_down_button" />

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_offset_circle_48_rose"
                android:contentDescription="@string/cd_decline_request"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_close_white_24"
                android:stateListAnimator="@animator/press_down_button" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
