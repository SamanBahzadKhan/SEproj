<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_palette_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/caps_palette_text_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_offset_circle_40_bell_admin"
            android:contentDescription="@string/cd_back"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/caps_palette_white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="Leave Feedback"
            android:textColor="@color/caps_palette_white"
            android:textSize="18sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_past_card_shadow" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_past_card_foreground"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_offset_avatar_44">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:tint="@color/caps_palette_white" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvCounselorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:textColor="@color/caps_palette_neutral_dark"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvSpecialization"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:textColor="@color/caps_palette_grey_warm"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvAppointmentDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:textColor="@color/caps_palette_grey_warm"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.12"
                android:text="RATE YOUR SESSION"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/rowStars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_star_rating_cell_empty"
                    android:contentDescription="1"
                    android:padding="10dp"
                    android:src="@drawable/ic_star_outline"
                    android:tint="@color/caps_palette_neutral_dark" />

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_star_rating_cell_empty"
                    android:contentDescription="2"
                    android:padding="10dp"
                    android:src="@drawable/ic_star_outline"
                    android:tint="@color/caps_palette_neutral_dark" />

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_star_rating_cell_empty"
                    android:contentDescription="3"
                    android:padding="10dp"
                    android:src="@drawable/ic_star_outline"
                    android:tint="@color/caps_palette_neutral_dark" />

                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_star_rating_cell_empty"
                    android:contentDescription="4"
                    android:padding="10dp"
                    android:src="@drawable/ic_star_outline"
                    android:tint="@color/caps_palette_neutral_dark" />

                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_star_rating_cell_empty"
                    android:contentDescription="5"
                    android:padding="10dp"
                    android:src="@drawable/ic_star_outline"
                    android:tint="@color/caps_palette_neutral_dark" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.12"
                android:text="YOUR COMMENTS"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_offset_input_12"
                android:fontFamily="sans-serif"
                android:gravity="top|start"
                android:hint="Share your experience with this counsellor..."
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="120dp"
                android:padding="14dp"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textColorHint="@color/caps_palette_grey_warm"
                android:textSize="15sp" />

            <FrameLayout
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_offset_btn_decline_rose"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="SUBMIT FEEDBACK"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="16sp" />
            </FrameLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
