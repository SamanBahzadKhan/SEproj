<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/caps_palette_neutral_dark" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/caps_palette_white" />
            <stroke android:width="2dp" android:color="@color/caps_palette_neutral_dark" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>