<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_palette_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@color/caps_palette_text_dark"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/caps_palette_white"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Report User"
                android:textColor="@color/caps_palette_white"
                android:textSize="18sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvReportingName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvReportingRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/caps_palette_grey_warm"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="sans-serif-black"
                    android:text="REPORT TYPE"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="11sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_offset_input_12">

                    <Spinner
                        android:id="@+id/spinnerReportType"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@android:color/transparent"
                        android:paddingHorizontal="12dp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-black"
                    android:text="WHAT HAPPENED?"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="11sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="124dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_offset_input_12">

                    <EditText
                        android:id="@+id/etReportSummary"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="sans-serif"
                        android:gravity="top"
                        android:hint="Briefly describe what happened..."
                        android:maxLines="6"
                        android:padding="12dp"
                        android:scrollbars="vertical"
                        android:textColor="@color/caps_palette_neutral_dark"
                        android:textColorHint="@color/caps_palette_grey_warm"
                        android:textSize="15sp" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_offset_button_rose_12"
                    android:stateListAnimator="@animator/press_down_button">

                    <Button
                        android:id="@+id/btnSubmitReport"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="sans-serif-black"
                        android:stateListAnimator="@animator/press_down_button"
                        android:text="SUBMIT REPORT"
                        android:textColor="@color/caps_palette_neutral_dark"
                        android:textSize="16sp" />
                </FrameLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/caps_palette_blue_grey"
        android:visibility="gone" />
</FrameLayout>
