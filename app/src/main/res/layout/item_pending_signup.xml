<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_offset_row_12"
    android:padding="12dp"
    android:stateListAnimator="@animator/press_down_button">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSignupName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvSignupSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/caps_palette_grey_warm"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/btnSignupApprove"
                android:layout_width="64dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_offset_report_remove_btn"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/press_down_button">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="✓"
                    android:textColor="@color/caps_palette_white"
                    android:textSize="18sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnSignupReject"
                android:layout_width="64dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_offset_report_ignore_btn"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/press_down_button">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="@color/caps_palette_neutral_dark"
                    android:textSize="18sp" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
