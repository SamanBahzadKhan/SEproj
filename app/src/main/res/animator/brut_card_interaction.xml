<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:duration="55"
                android:propertyName="translationY"
                android:valueTo="5"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="55"
                android:propertyName="translationX"
                android:valueTo="4"
                android:valueType="floatType" />
        </set>
    </item>
    <item android:state_hovered="true">
        <objectAnimator
            android:duration="90"
            android:propertyName="translationZ"
            android:valueTo="4"
            android:valueType="floatType" />
    </item>
    <item>
        <set>
            <objectAnimator
                android:duration="90"
                android:propertyName="translationY"
                android:valueTo="0"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="90"
                android:propertyName="translationX"
                android:valueTo="0"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="90"
                android:propertyName="translationZ"
                android:valueTo="0"
                android:valueType="floatType" />
        </set>
    </item>
</selector>
