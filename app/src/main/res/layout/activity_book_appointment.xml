<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_palette_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/caps_palette_blue_grey"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_offset_appointment_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_offset_avatar_admin_52">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="@color/caps_palette_white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCounselorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/caps_palette_neutral_dark"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif"
                        android:text="★★★★☆ 4.5"
                        android:textColor="@color/caps_palette_grey_warm"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textAllCaps="true"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llDateChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvNoAvailability"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="16dp"
            android:textColor="@color/caps_palette_grey_warm"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/llPeriods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Time Slot"
                android:textAllCaps="true"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPickMorning"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/caps_palette_neutral_dark"
                    app:strokeWidth="2dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Morning\n8 AM – 4 PM"
                        android:textAlignment="center"
                        android:textColor="@color/caps_palette_neutral_dark"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPickAfternoon"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/caps_palette_neutral_dark"
                    app:strokeWidth="2dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Afternoon\n4 PM – 12 AM"
                        android:textAlignment="center"
                        android:textColor="@color/caps_palette_neutral_dark"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/labelSelectTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Select Time Slot"
            android:textAllCaps="true"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black"
            android:visibility="gone" />

        <GridLayout
            android:id="@+id/gridTimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Appointment Type"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black" />

        <RadioGroup
            android:id="@+id/rgType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbInPerson"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:checked="true"
                android:button="@null"
                android:gravity="center"
                android:background="@drawable/bg_type_radio_selector"
                android:text="In-Person"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/rbOnline"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:button="@null"
                android:gravity="center"
                android:background="@drawable/bg_type_radio_selector"
                android:text="Online"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textStyle="bold" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Notes (Optional)"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_offset_input_12"
            android:gravity="top|start"
            android:hint="Add any notes for your counsellor..."
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="@color/caps_palette_neutral_dark"
            android:textColorHint="@color/caps_palette_grey_warm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_offset_done_button"
            android:stateListAnimator="@animator/press_down_button"
            android:text="DONE"
            android:textColor="@color/caps_palette_white"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:iconPadding="0dp" />
    </LinearLayout>
</ScrollView>
