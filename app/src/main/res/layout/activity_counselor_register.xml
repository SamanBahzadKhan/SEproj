<?xml version="1.0" encoding="utf-8"?>
<!-- Counsellor registration: neubrutalist form card (matches student sign-up + login). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caps_palette_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Counsellor Registration"
                android:textAlignment="center"
                android:textColor="@color/caps_palette_neutral_dark"
                android:textSize="26sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:text="Create your professional account"
                android:textAlignment="center"
                android:textColor="@color/caps_palette_blue"
                android:textSize="15sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_offset_form_card_20"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:hint="Full Name"
                            android:inputType="textPersonName"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:hint="Email"
                            android:inputType="textEmailAddress"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:hint="Password"
                            android:inputType="textPassword"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etSpecialization"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:hint="Specialization"
                            android:inputType="text"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etDepartment"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:hint="Department"
                            android:inputType="text"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etPhone"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:hint="Phone Number"
                            android:inputType="phone"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:minHeight="120dp"
                        android:background="@drawable/bg_offset_input_12">

                        <EditText
                            android:id="@+id/etBio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif"
                            android:gravity="top|start"
                            android:hint="Tell students about yourself..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="4"
                            android:paddingHorizontal="14dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textColor="@color/caps_palette_neutral_dark"
                            android:textColorHint="@color/caps_palette_grey_warm"
                            android:textSize="15sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_offset_button_blue_primary_12">

                        <Button
                            android:id="@+id/btnRegister"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-black"
                            android:stateListAnimator="@null"
                            android:text="REGISTER AS COUNSELLOR"
                            android:textAllCaps="true"
                            android:textColor="@color/caps_palette_white"
                            android:textSize="14sp" />
                    </FrameLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/caps_palette_brown"
        android:visibility="gone" />
</FrameLayout>
